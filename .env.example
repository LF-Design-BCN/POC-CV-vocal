# Clé API Anthropic, pour la génération de la lettre de motivation
ANTHROPIC_API_KEY=

# ID de l'agent ElevenLabs Conversational AI (créé dans leur dashboard).
# Doit être exposé côté navigateur pour charger le widget web, d'où le
# préfixe NEXT_PUBLIC_.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Secret partagé pour vérifier les webhooks ElevenLabs (voir dashboard ElevenLabs > Webhooks)
ELEVENLABS_WEBHOOK_SECRET=

# UPSTASH_REDIS_REST_URL et UPSTASH_REDIS_REST_TOKEN ne sont PAS à remplir ici :
# elles sont injectées automatiquement par l'intégration Upstash sur Vercel,
# ou récupérées en local via `vercel env pull .env.local` (voir README).

# --- Pour plus tard, quand le vrai appel téléphonique (Twilio) sera possible ---
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_AGENT_PHONE_NUMBER_ID=
